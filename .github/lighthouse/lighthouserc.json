{
  "ci": {
    "collect": {
      "staticDistDir": "./_site",
      "url": [
        "/index.html",
        "/seminars.html",
        "/research.html",
        "/courses.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.8 }],
        "categories:seo": ["warn", { "minScore": 0.8 }]
      }
    }
  }
}
